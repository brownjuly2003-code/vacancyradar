# Public artifact base. Current production path is the Hugging Face Dataset
# mirror; Vercel Blob remains a legacy fallback and publish commands skip Blob
# PUT when this URL points to huggingface.co.
BLOB_PUBLIC_BASE_URL=https://huggingface.co/datasets/<owner>/vacancyradar-data/resolve/main

# Vercel Blob legacy fallback only. Leave empty in HF-primary mode.
BLOB_READ_WRITE_TOKEN=

# Hugging Face Dataset mirror — primary public artifact host. Token is only
# for the publishing machine; frontend reads public artifacts via
# BLOB_PUBLIC_BASE_URL.
HF_REPO_ID=<owner>/vacancyradar-data
HF_TOKEN=
HF_REVISION=main

# Neon Postgres — primary backend для /api/search + Neon `aggregates` fallback
# for /api/facets и /api/trends/*. Free tier 512 MB Frankfurt EU Central
# region; нет card. Создаётся через https://console.neon.tech (Google OAuth),
# затем connection strings копируются сюда.
# Read-only DSN is preferred by web/lib/neon.ts for Vercel/runtime reads.
NEON_READ_DATABASE_URL=postgresql://<readonly_user>:<pwd>@<host>/<db>?sslmode=require

# Owner/write DSN is used by `vradar publish neon` on the publishing machine.
# web/lib/neon.ts falls back to this only when NEON_READ_DATABASE_URL is absent.
NEON_DATABASE_URL=postgresql://<user>:<pwd>@<host>/<db>?sslmode=require

# Feature flag для web/app/api/search/route.ts. Если "neon" — search идёт
# на Neon Postgres (pg_trgm GIN ILIKE), при failure cascade'ит на DuckDB+httpfs
# Blob path. Если пусто или "duckdb" — только DuckDB+httpfs.
# Vercel production+preview: neon. Local dev: можно оставить пустым.
SEARCH_BACKEND=neon

# hh.ru access token — НУЖЕН ТОЛЬКО для `--transport api` (OAuth fallback).
# Default transport=shards использует hh.ru/shards/vacancy/search через curl_cffi
# (Chrome JA3) и НЕ требует токена. Получить — `python -m src.cli auth hh ...`
# после регистрации app на https://dev.hh.ru/admin (без card).
HH_ACCESS_TOKEN=

# Telegram (Telethon) — нужен для Phase 4
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION=vradar_session

# Optional: LLM fallback for ambiguous text parsing
ANTHROPIC_API_KEY=
