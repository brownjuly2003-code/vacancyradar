# Hugging Face Dataset mirror — the public artifact host. Token is only
# needed on the publishing (collection) machine; all consumers read the
# public dataset without auth.
HF_REPO_ID=<owner>/vacancyradar-data
HF_TOKEN=
HF_REVISION=main

# hh.ru access token — НУЖЕН ТОЛЬКО для `--transport api` (OAuth fallback).
# Default transport=shards использует hh.ru/shards/vacancy/search через curl_cffi
# (Chrome JA3) и НЕ требует токена. Получить — `python -m src.cli auth hh ...`
# после регистрации app на https://dev.hh.ru/admin (без card).
HH_ACCESS_TOKEN=

# Telegram (Telethon)
TG_API_ID=
TG_API_HASH=
TG_PHONE=
TG_SESSION=vradar_session
# Optional: route Telethon through a SOCKS proxy (socks5://[user:pass@]host:port).
# Needed on hosts whose direct line cannot reach Telegram DCs (e.g. clean-IP
# collection host behind RKN block); requires `pip install python-socks`.
TG_PROXY=

# Optional: LLM fallback for ambiguous text parsing
ANTHROPIC_API_KEY=
